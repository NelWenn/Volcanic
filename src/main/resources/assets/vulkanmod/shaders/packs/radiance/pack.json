{
    "name": "Camille Radiance",
    "version": 14,
    "targets": [
        { "name": "light",    "format": "RGBA16F", "scale": 0.5,  "clear": 1.0 },
        { "name": "scenblur", "format": "RGBA16F", "scale": 0.25 }
    ],
    "passes": [
        { "name": "light",     "program": "radiance_light",     "inputs": { "0": "depthtex", "1": "fgdepth", "2": "shadowtex" }, "output": "light" },
        { "name": "blur",      "program": "radiance_blur",      "inputs": { "0": "scene" }, "output": "scenblur" },
        { "name": "composite", "program": "radiance_composite", "inputs": { "0": "scene", "1": "depthtex", "2": "fgdepth", "3": "light", "4": "scenblur" }, "output": "swapchain" }
    ]
}
